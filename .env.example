# AWS (Required - get from AWS Console > IAM)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# Nova Models
NOVA_MODEL_ID=us.amazon.nova-lite-v1:0
NOVA_EMBED_MODEL_ID=amazon.nova-embed-v1:0

# Farm Location
FARM_LAT=27.7
FARM_LON=85.3
FARM_LANGUAGE=en

# Alerts
NTFY_TOPIC=paws-farm-demo
NTFY_BASE_URL=https://ntfy.sh
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_IDS=your_chat_id
PUBLIC_BASE_URL=http://localhost:8000

# Modal
MODAL_WEBHOOK_SECRET=your_secret
MODAL_STREAM_URL=

# Edge device (optional)
EDGE_DEVICE_URL=

# Thresholds
ALERT_SEVERITY_THRESHOLD=4
DETERRENT_SEVERITY_THRESHOLD=6
AUTHORITY_SEVERITY_THRESHOLD=8
DETECTION_COOLDOWN_SECONDS=30

# Dataset / detections dirs
DATASET_DIR=dataset
DETECTIONS_DIR=detections
